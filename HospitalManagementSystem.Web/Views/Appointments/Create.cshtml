@model HospitalManagementSystem.Web.Models.Appointment

@{
    ViewData["Title"] = "Yeni Randevu Ekle";
}

<div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Index" class="p-2 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h1 class="text-2xl font-bold text-slate-800">Yeni Randevu Ekle</h1>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8">
        <form asp-action="Create" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="p-4 bg-red-50 text-red-700 rounded-lg text-sm"></div>

            <div>
                <label asp-for="PatientId" class="block text-sm font-medium text-slate-700 mb-1.5">Hasta *</label>
                <select asp-for="PatientId" asp-items="ViewBag.Patients"
                        class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700">
                    <option value="">-- Hasta Seçin --</option>
                </select>
                <span asp-validation-for="PatientId" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="DoctorId" class="block text-sm font-medium text-slate-700 mb-1.5">Doktor *</label>
                <select asp-for="DoctorId" asp-items="ViewBag.Doctors"
                        class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700">
                    <option value="">-- Doktor Seçin --</option>
                </select>
                <span asp-validation-for="DoctorId" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="AppointmentDate" class="block text-sm font-medium text-slate-700 mb-1.5">Randevu Tarihi & Saati *</label>
                <input asp-for="AppointmentDate" type="datetime-local"
                       class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700" />
                <span asp-validation-for="AppointmentDate" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Status" class="block text-sm font-medium text-slate-700 mb-1.5">Durum *</label>
                <select asp-for="Status"
                        class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700">
                    <option value="Onaylandı">Onaylandı</option>
                    <option value="Bekliyor">Bekliyor</option>
                    <option value="Tamamlandı">Tamamlandı</option>
                    <option value="İptal">İptal</option>
                </select>
            </div>

            <div>
                <label asp-for="Notes" class="block text-sm font-medium text-slate-700 mb-1.5">Notlar</label>
                <textarea asp-for="Notes" rows="3" placeholder="Randevu ile ilgili notlar..."
                          class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700 resize-none"></textarea>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="bg-primary hover:bg-primaryHover text-white font-medium px-6 py-2.5 rounded-lg transition-colors shadow-sm flex items-center gap-2">
                    <i class="fa-solid fa-floppy-disk"></i> Kaydet
                </button>
                <a asp-action="Index" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium px-6 py-2.5 rounded-lg transition-colors">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>
