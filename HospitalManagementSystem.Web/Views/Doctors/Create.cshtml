@model HospitalManagementSystem.Web.Models.Doctor

@{
    ViewData["Title"] = "Yeni Doktor Ekle";
}

<div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Index" class="p-2 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h1 class="text-2xl font-bold text-slate-800">Yeni Doktor Ekle</h1>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8">
        <form asp-action="Create" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="p-4 bg-red-50 text-red-700 rounded-lg text-sm"></div>

            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-slate-700 mb-1.5">Ad Soyad *</label>
                <input asp-for="FullName" placeholder="Örn: Dr. Mehmet Öz"
                       class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700" />
                <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Specialization" class="block text-sm font-medium text-slate-700 mb-1.5">Uzmanlık Alanı *</label>
                <input asp-for="Specialization" placeholder="Örn: Kardiyoloji"
                       class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700" />
                <span asp-validation-for="Specialization" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Phone" class="block text-sm font-medium text-slate-700 mb-1.5">Telefon *</label>
                    <input asp-for="Phone" placeholder="055x xxx xx xx"
                           class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700" />
                    <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="RoomNumber" class="block text-sm font-medium text-slate-700 mb-1.5">Oda / Poliklinik</label>
                    <input asp-for="RoomNumber" placeholder="Örn: K-02"
                           class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700" />
                </div>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1.5">E-Posta</label>
                <input asp-for="Email" type="email" placeholder="doktor@hastane.com"
                       class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700" />
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="bg-primary hover:bg-primaryHover text-white font-medium px-6 py-2.5 rounded-lg transition-colors shadow-sm flex items-center gap-2">
                    <i class="fa-solid fa-floppy-disk"></i> Kaydet
                </button>
                <a asp-action="Index" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium px-6 py-2.5 rounded-lg transition-colors">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>
