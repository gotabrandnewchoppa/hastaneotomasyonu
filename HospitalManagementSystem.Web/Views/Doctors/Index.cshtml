@model IEnumerable<HospitalManagementSystem.Web.Models.Doctor>

@{
    ViewData["Title"] = "Doktorlar";
}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-slate-800 dark:text-white">Doktor Listesi</h1>
    <a asp-action="Create" class="bg-primary hover:bg-primaryHover text-white px-5 py-2.5 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
        <i class="fa-solid fa-plus"></i>Yeni Doktor Ekle
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var doctor in Model)
    {
        <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6 flex flex-col items-center text-center shadow-sm hover:shadow-md transition-shadow group cursor-pointer relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-primary transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
            <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(doctor.FullName)&background=0D8ABC&color=fff&rounded=true&size=128"
                 alt="@doctor.FullName"
                 class="w-24 h-24 rounded-full shadow-sm mb-4 border-4 border-slate-50 dark:border-slate-700 group-hover:border-blue-100 dark:group-hover:border-blue-900 transition-colors" />
            <h3 class="text-lg font-bold text-slate-800 dark:text-white">@doctor.FullName</h3>
            <p class="text-sm font-medium text-blue-500 dark:text-blue-400 mb-2">@doctor.Specialization</p>
            @if (!string.IsNullOrEmpty(doctor.RoomNumber))
            {
                <p class="text-xs text-slate-500 dark:text-slate-400 mb-2">Oda: @doctor.RoomNumber</p>
            }
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">
                <i class="fa-solid fa-phone text-slate-400 dark:text-slate-500 mr-1"></i>@doctor.Phone
            </p>

            <div class="w-full flex justify-between border-t border-slate-100 dark:border-slate-700 mt-auto pt-4">
                <a asp-controller="Appointments" asp-action="Index" class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors flex items-center gap-2">
                    <i class="fa-regular fa-calendar-check"></i> Randevular
                </a>
                <div class="flex gap-1">
                    <a asp-action="Edit" asp-route-id="@doctor.Id"
                       class="w-8 h-8 rounded-full bg-slate-50 dark:bg-slate-700 text-slate-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 hover:text-blue-600 dark:hover:text-blue-400 transition-colors flex items-center justify-center"
                       title="Düzenle">
                        <i class="fa-regular fa-pen-to-square text-sm"></i>
                    </a>
                    <form asp-action="Delete" asp-route-id="@doctor.Id" method="post" class="inline"
                          onsubmit="return confirm('Bu doktoru silmek istediğinize emin misiniz?');">
                        <button type="submit"
                                class="w-8 h-8 rounded-full bg-slate-50 dark:bg-slate-700 text-slate-400 hover:bg-red-50 dark:hover:bg-red-900/30 hover:text-red-600 dark:hover:text-red-400 transition-colors flex items-center justify-center"
                                title="Sil">
                            <i class="fa-regular fa-trash-can text-sm"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-span-3 py-16 text-center text-slate-500 dark:text-slate-400">
            <i class="fa-solid fa-user-doctor text-4xl text-slate-300 dark:text-slate-600 mb-4 block"></i>
            Kayıtlı doktor bulunamadı.
        </div>
    }
</div>
