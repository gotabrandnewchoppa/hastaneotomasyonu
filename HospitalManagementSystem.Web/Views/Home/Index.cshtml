@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- İstatistik Kartları -->
    <div class="bg-white dark:bg-slate-800 rounded-xl p-5 border border-slate-100 dark:border-slate-700 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-500 dark:text-blue-400 flex items-center justify-center text-xl">
            <i class="fa-solid fa-users"></i>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Toplam Hasta</p>
            <h3 class="text-2xl font-bold text-slate-800 dark:text-white">1,248</h3>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-xl p-5 border border-slate-100 dark:border-slate-700 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-full bg-emerald-50 dark:bg-emerald-900/30 text-emerald-500 dark:text-emerald-400 flex items-center justify-center text-xl">
            <i class="fa-solid fa-user-doctor"></i>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Aktif Doktor</p>
            <h3 class="text-2xl font-bold text-slate-800 dark:text-white">45</h3>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-xl p-5 border border-slate-100 dark:border-slate-700 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-full bg-amber-50 dark:bg-amber-900/30 text-amber-500 dark:text-amber-400 flex items-center justify-center text-xl">
            <i class="fa-solid fa-calendar-check"></i>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Bugünkü Randevular</p>
            <h3 class="text-2xl font-bold text-slate-800 dark:text-white">124</h3>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-xl p-5 border border-slate-100 dark:border-slate-700 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-full bg-rose-50 dark:bg-rose-900/30 text-rose-500 dark:text-rose-400 flex items-center justify-center text-xl">
            <i class="fa-solid fa-bed-pulse"></i>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Yatan Hasta</p>
            <h3 class="text-2xl font-bold text-slate-800 dark:text-white">32</h3>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-100 dark:border-slate-700 shadow-sm p-6 line-chart-container">
        <h2 class="text-lg font-bold text-slate-800 dark:text-white mb-4">Haftalık Hasta İstatistiği</h2>
        <div class="h-64 bg-slate-50 dark:bg-slate-900 rounded-lg border border-dashed border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400 dark:text-slate-500">
            [Grafik Alanı - Chart.js eklenebilir]
        </div>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-100 dark:border-slate-700 shadow-sm p-6">
        <h2 class="text-lg font-bold text-slate-800 dark:text-white mb-4">Yaklaşan Randevular</h2>
        <div class="space-y-4">
            <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-900 rounded-lg border border-slate-100 dark:border-slate-700">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center font-bold">AH</div>
                    <div>
                        <p class="font-medium text-slate-800 dark:text-slate-200">Ahmet Yılmaz</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Genel Cerrahi - Dr. Mehmet Öz</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="font-bold text-slate-800 dark:text-white">14:30</p>
                    <p class="text-xs text-blue-500 dark:text-blue-400 font-medium">Bugün</p>
                </div>
            </div>
            <!-- More dummy items can be added here -->
        </div>
    </div>
</div>
