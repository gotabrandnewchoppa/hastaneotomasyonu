@model IEnumerable<HospitalManagementSystem.Web.Models.LabReport>

@{
    ViewData["Title"] = "Lab Raporları";
    var patient = ViewBag.Patient as HospitalManagementSystem.Web.Models.Patient;
}

<div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-4 mb-6">
        <a asp-controller="Patients" asp-action="Index"
           class="p-2 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Lab Raporları</h1>
            <p class="text-sm text-slate-500">@patient?.FullName</p>
        </div>
        <div class="ml-auto flex gap-3">
            <a asp-controller="Patients" asp-action="ExportPdf" asp-route-id="@patient?.Id"
               class="bg-rose-600 hover:bg-rose-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 text-sm shadow-sm">
                <i class="fa-solid fa-file-pdf"></i> PDF Raporu
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg text-sm flex items-center gap-2">
            <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 p-3 bg-red-50 border border-red-100 text-red-700 rounded-lg text-sm flex items-center gap-2">
            <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
        </div>
    }

    <!-- Upload Form -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
        <h2 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
            <i class="fa-solid fa-upload text-primary"></i> Yeni Dosya Yükle
        </h2>
        <form asp-controller="Patients" asp-action="Upload" asp-route-id="@patient?.Id"
              method="post" enctype="multipart/form-data" class="space-y-4">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Dosya (PDF, JPG, PNG, DOCX – maks. 10 MB)</label>
                    <input type="file" name="file" accept=".pdf,.jpg,.jpeg,.png,.docx" required
                           class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700
                                  file:mr-4 file:py-1.5 file:px-4 file:rounded-md file:border-0
                                  file:text-sm file:font-medium file:bg-primary file:text-white
                                  hover:file:bg-primaryHover cursor-pointer" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Açıklama (isteğe bağlı)</label>
                    <input type="text" name="description" placeholder="Örn: Kan tahlili"
                           class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-slate-700 text-sm" />
                </div>
            </div>
            <button type="submit"
                    class="bg-primary hover:bg-primaryHover text-white font-medium px-5 py-2.5 rounded-lg transition-colors shadow-sm text-sm flex items-center gap-2">
                <i class="fa-solid fa-cloud-arrow-up"></i> Yükle
            </button>
        </form>
    </div>

    <!-- File List -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
            <h2 class="font-bold text-slate-800">Yüklü Dosyalar</h2>
            <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full">
                @Model.Count() dosya
            </span>
        </div>

        @if (!Model.Any())
        {
            <div class="py-16 text-center text-slate-500">
                <i class="fa-regular fa-folder-open text-4xl text-slate-300 mb-3 block"></i>
                Henüz dosya yüklenmemiş.
            </div>
        }
        else
        {
            <div class="divide-y divide-slate-100">
                @foreach (var report in Model)
                {
                    var icon = report.ContentType switch {
                        "application/pdf" => "fa-file-pdf text-red-500",
                        "image/jpeg" or "image/png" => "fa-file-image text-blue-500",
                        _ => "fa-file-word text-indigo-500"
                    };
                    var size = report.FileSizeBytes >= 1024 * 1024
                        ? $"{report.FileSizeBytes / (1024.0 * 1024):F1} MB"
                        : $"{report.FileSizeBytes / 1024.0:F0} KB";

                    <div class="p-4 flex items-center gap-4 hover:bg-slate-50 transition-colors">
                        <i class="fa-solid @icon text-2xl w-8 text-center flex-shrink-0"></i>
                        <div class="flex-1 min-w-0">
                            <p class="font-medium text-slate-800 truncate">@report.OriginalName</p>
                            <p class="text-xs text-slate-500">
                                @size · @report.UploadedAt.ToString("dd.MM.yyyy HH:mm")
                                @if (!string.IsNullOrEmpty(report.Description))
                                {
                                    <span> · @report.Description</span>
                                }
                            </p>
                        </div>
                        <div class="flex gap-2">
                            <a asp-controller="Patients" asp-action="Download" asp-route-id="@report.Id"
                               class="px-3 py-1.5 text-xs font-medium text-primary hover:bg-blue-50 rounded-lg transition-colors flex items-center gap-1.5">
                                <i class="fa-solid fa-download"></i> İndir
                            </a>
                            <form asp-controller="Patients" asp-action="DeleteFile" asp-route-id="@report.Id"
                                  method="post" onsubmit="return confirm('Bu dosyayı silmek istediğinize emin misiniz?');">
                                <button type="submit"
                                        class="px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 rounded-lg transition-colors flex items-center gap-1.5">
                                    <i class="fa-regular fa-trash-can"></i> Sil
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
